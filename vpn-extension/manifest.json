{
  "manifest_version": 3,
  "name": "MOVTI VPN Shield",
  "version": "1.0.1",
  "description": "فیلترشکن قدرتمند با رابط کاربری مدرن | Powerful VPN with Modern UI",
  "permissions": [
    "proxy",
    "storage",
    "tabs",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.myip.com/*",
    "https://ipinfo.io/*",
    "http://ip-api.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
